{
    "layer": "top",
    "modules-center": [
        "clock",
        "hyprland/workspaces",
        "pulseaudio",
        "network",
        "battery"
    ],
    "clock"{
        "clock": {
            "interval": 60,
            "format": "{:%H:%M}",
            "max-length": 25
        }
    }
}